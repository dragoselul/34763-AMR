{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Project",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "Project"
      ],
      "cwd": "${workspaceFolder}",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
